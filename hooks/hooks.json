{
  "description": "MCP security guard hooks: inspect MCP tool descriptions, log every MCP tool call, and audit MCP server configs on disk.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/mcp_guard.py\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/mcp_guard.py\" audit",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/mcp_guard.py\" inspect",
            "timeout": 120,
            "async": true,
            "statusMessage": "Inspecting MCP servers"
          }
        ]
      }
    ]
  }
}
